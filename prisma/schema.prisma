generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Bookmark {
  id        String   @id
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model Comment {
  id            String    @id
  videoId       String
  userId        String
  content       String
  parentId      String?
  createdAt     DateTime  @default(now())
  Comment       Comment?  @relation("CommentToComment", fields: [parentId], references: [id])
  other_Comment Comment[] @relation("CommentToComment")
  User          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Video         Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id
  userId    String
  videoId   String
  content   String
  timestamp Int
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Progress {
  id             String  @id
  userId         String
  videoId        String
  watchedSeconds Int     @default(0)
  isCompleted    Boolean @default(false)
  User           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  Video          Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model User {
  id        String     @id
  name      String
  avatar    String?    @default("1.png")
  phone     String     @unique
  email     String?    @unique
  password  String?
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  Bookmark  Bookmark[]
  Comment   Comment[]
  Like      Like[]
  Note      Note[]
  Progress  Progress[]
}

model Video {
  id          String        @id
  title       String
  description String
  url         String
  categoryId  String?
  toolsNeeded String[]      @default([])
  createdAt   DateTime      @default(now())
  Bookmark    Bookmark[]
  Category    Category?     @relation(fields: [categoryId], references: [id])
  Comment     Comment[]
  Like        Like[]
  Note        Note[]
  Progress    Progress[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  videos    Video[]
}

enum Role {
  ADMIN
  USER
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  coverImage  String
  content     String
  tag         String   @default("Artikel")
  createdAt   DateTime @default(now())
}

